{
  "name": "pretext-table",
  "version": "0.0.0",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./src/index.ts"
    },
    "./style.css": "./src/style.css"
  },
  "files": [
    "lib",
    "src"
  ],
  "scripts": {
    "generate": "npx tsx src/generate-data.ts",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "tsc && vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "apache-arrow": ">=15"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "apache-arrow": "^21.1.0",
    "parquet-wasm": "^0.7.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semiotic": "^3.2.2",
    "tslib": "^2.8.1"
  }
}
